rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net (Rule 1)
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitive Definitions (Rule 3)
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation Blueprint for UserProfile Entity (Rule 2)
    function isValidUserProfile(data, userId) {
      return data.keys().hasAll(['userId', 'updatedAt']) &&
             data.userId == userId &&
             data.userId == request.auth.uid &&
             (!('themeId' in data) || (data.themeId is string && data.themeId.size() <= 64)) &&
             (!('isDarkMode' in data) || data.isDarkMode is bool) &&
             (!('showClock' in data) || data.showClock is bool) &&
             (!('showStatusBar' in data) || data.showStatusBar is bool) &&
             (!('fontPreference' in data) || (data.fontPreference is string && data.fontPreference.size() <= 32)) &&
             (!('keySoundsEnabled' in data) || data.keySoundsEnabled is bool) &&
             (!('keySoundProfile' in data) || (data.keySoundProfile is string && data.keySoundProfile.size() <= 32)) &&
             (!('focusMode' in data) || data.focusMode is bool) &&
             data.updatedAt is timestamp;
    }

    // Validation Blueprint for Note Entity (Rule 2)
    function isValidNote(data, userId) {
      return data.keys().hasAll(['id', 'userId', 'title', 'content', 'updatedAt']) &&
             data.keys().size() == 5 &&
             data.id is string &&
             data.id.size() <= 128 &&
             data.userId == userId &&
             data.userId == request.auth.uid &&
             data.title is string &&
             data.title.size() <= 200 &&
             data.content is string &&
             data.content.size() <= 1048576 && // Max 1MB
             data.updatedAt is int;
    }

    // User Profile Rules
    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId && isValidId(userId);
      
      allow create: if isSignedIn() && 
                       request.auth.uid == userId && 
                       isValidId(userId) && 
                       isValidUserProfile(incoming(), userId) &&
                       incoming().updatedAt == request.time;
                       
      allow update: if isSignedIn() && 
                       request.auth.uid == userId && 
                       isValidId(userId) && 
                       isValidUserProfile(incoming(), userId) &&
                       incoming().updatedAt == request.time &&
                       incoming().userId == existing().userId;
                       
      allow delete: if false; // Profiles shouldn't be deleted by client

      // Notes Subcollection
      match /notes/{noteId} {
        allow get: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && isValidId(noteId);
        
        allow list: if isSignedIn() && request.auth.uid == userId && isValidId(userId);
        
        allow create: if isSignedIn() && 
                         request.auth.uid == userId && 
                         isValidId(userId) && 
                         isValidId(noteId) && 
                         isValidNote(incoming(), userId);
                         
        allow update: if isSignedIn() && 
                         request.auth.uid == userId && 
                         isValidId(userId) && 
                         isValidId(noteId) && 
                         isValidNote(incoming(), userId) &&
                         incoming().id == existing().id &&
                         incoming().userId == existing().userId;
                         
        allow delete: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && isValidId(noteId);
      }
    }
  }
}
